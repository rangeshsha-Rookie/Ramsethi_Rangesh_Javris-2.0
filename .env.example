# PhishGuard India - Environment Variables

# MongoDB Atlas Connection String
# Get this from cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/phishguard?retryWrites=true&w=majority

# NVIDIA NIM API Key (Optional if using local fallbacks)
# Get this from build.nvidia.com
nvidia_api_key=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Polygon Amoy Private Key (For blockchain interaction)
# NEVER commit your actual private key!
BLOCKCHAIN_PRIVATE_KEY=0x123456789abcdef123456789abcdef123456789abcdef123456789abcdef

# Contract Address (From Phase 5)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
